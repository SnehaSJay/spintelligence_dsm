PORT=4001
CORS_ORIGINS=http://localhost:3000,http://192.168.1.16:3000

DB_TARGET=local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quality_control
DB_USER=postgres
DB_PASSWORD=change-me
DB_SSL=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000

# SQL Server (for external master/dropdown reads)
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=master
MSSQL_PREP_DATABASE=dsmprojects
MSSQL_THRESHOLD_TABLE=dbo.threshold_master
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERT=true
MSSQL_POOL_MAX=10
MSSQL_POOL_IDLE_MS=30000
MSSQL_CONNECT_TIMEOUT_MS=15000
MSSQL_REQUEST_TIMEOUT_MS=30000
DATABASE_URL=
DATABASE_URL_LOCAL=postgresql://postgres:change-me@localhost:5432/quality_control
DATABASE_URL_SUPABASE=postgresql://username:password@host:5432/postgres?sslmode=require
SUPABASE_MIRROR_ENABLED=true

JWT_SECRET=replace-with-random-jwt-secret
JWT_EXPIRES_IN=8h
ADMIN_JWT_SECRET=replace-with-random-admin-jwt-secret
OTP_SECRET=replace-with-random-otp-secret
BCRYPT_SALT_ROUNDS=10

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_PASSWORD_HASH=

REPORT_SCHEDULE_INTERVAL_MS=60000
REPORT_SCHEDULE_WORKER_ENABLED=true
REPORT_EMAIL_PROVIDER=smtp
REPORT_SENDER_NAME=Support Team
