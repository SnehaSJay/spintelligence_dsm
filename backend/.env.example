REPORT_SMTP_USER=
REPORT_SMTP_PASS=
SMTP_USER=
SMTP_PASS=
EMAIL_USER=
EMAIL_PASS=
GMAIL_APP_PASSWORD=

OCR_UPSTREAM_TIMEOUT_MS=15000
OCR_STREAM_TIMEOUT_MS=240000
OCR_LOCAL_TIMEOUT_MS=240000
# Disable this on Windows machines where Node child_process.spawn is blocked.
OCR_LOCAL_FALLBACK_ENABLED=true
